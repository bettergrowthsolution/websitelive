    <script>
        (function() {
            'use strict';

            const hamburger = document.getElementById('hamburger');
            const navList = document.getElementById('navList');
            hamburger.addEventListener('click', function() {
                this.classList.toggle('open');
                navList.classList.toggle('open');
            });
            document.querySelectorAll('.nav-list a').forEach(link => {
                link.addEventListener('click', function() {
                    hamburger.classList.remove('open');
                    navList.classList.remove('open');
                });
            });

            const header = document.getElementById('header');
            window.addEventListener('scroll', function() {
                header.classList.toggle('scrolled', window.pageYOffset > 30);
            });

            const revealElements = document.querySelectorAll('.reveal');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
            }, { threshold: 0.10, rootMargin: '0px 0px -40px 0px' });
            revealElements.forEach(el => observer.observe(el));

            // Word Counter
            const coverLetter = document.getElementById('coverLetter');
            const wordCountDisplay = document.getElementById('wordCountDisplay');
            coverLetter.addEventListener('input', function() {
                const text = this.value.trim();
                const wordCount = text ? text.split(/\s+/).filter(w => w.length > 0).length : 0;
                wordCountDisplay.textContent = wordCount;
                wordCountDisplay.classList.toggle('warning', wordCount > 100);
            });

            // Form Handler
            const form = document.getElementById('careerForm');
            const submitBtn = document.getElementById('submitBtn');
            form.addEventListener('submit', async function(e) {
                e.preventDefault();

                const text = coverLetter.value.trim();
                const wordCount = text ? text.split(/\s+/).filter(w => w.length > 0).length : 0;
                if (wordCount > 100) {
                    alert('Your cover letter exceeds the 100-word limit. Please shorten it to continue.');
                    coverLetter.focus();
                    return;
                }
                if (wordCount === 0) {
                    alert('Please write a cover letter (up to 100 words).');
                    coverLetter.focus();
                    return;
                }
                if (!document.getElementById('termsCheckbox').checked) {
                    alert('Please agree to the Terms & Conditions to proceed with your application.');
                    return;
                }

                const formData = new FormData(form);
                const originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting…';
                submitBtn.disabled = true;

                try {
                    const response = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData });
                    const data = await response.json();
                    if (response.ok && data.success) {
                        submitBtn.innerHTML = '<i class="fas fa-check"></i> Application Submitted!';
                        submitBtn.className = 'btn btn-success';
                        submitBtn.disabled = false;
                        setTimeout(() => {
                            form.reset();
                            wordCountDisplay.textContent = '0';
                            wordCountDisplay.classList.remove('warning');
                            submitBtn.innerHTML = originalText;
                            submitBtn.className = 'btn btn-primary';
                            document.querySelector('.career-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
                        }, 4500);
                    } else {
                        alert('Error: ' + (data.message || 'Something went wrong. Please try again.'));
                        submitBtn.innerHTML = originalText;
                        submitBtn.disabled = false;
                    }
                } catch (error) {
                    alert('Something went wrong. Please try again or email us directly at hr@bettergrowthsolutions.com');
                    submitBtn.innerHTML = originalText;
                    submitBtn.disabled = false;
                }
            });
        })();
    </script>
