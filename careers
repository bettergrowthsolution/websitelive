        .career-card .intro-text h2 .highlight { color: var(--accent); }
        .career-card .intro-text p { color: var(--text-body); opacity: 0.7; font-size: 1.05rem; }
        .career-card .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .career-card .form-group { display: flex; flex-direction: column; gap: 4px; margin-bottom: 14px; }
        .career-card .form-group.full { grid-column: 1 / -1; }
        .career-card label { font-size: 0.8rem; font-weight: 600; color: var(--text-body); letter-spacing: 0.02em; text-transform: uppercase; opacity: 0.7; }
        .career-card label .required { color: #ef4444; margin-left: 2px; }
        .career-card input, .career-card select, .career-card textarea { background: #fff; border: 1px solid rgba(11,26,51,0.08); border-radius: var(--radius-sm); padding: 12px 16px; font-family: var(--font); font-size: 0.95rem; color: var(--text-body); transition: var(--transition); outline: none; width: 100%; }
        .career-card input::placeholder, .career-card textarea::placeholder { color: rgba(11,26,51,0.25); }
        .career-card input:focus, .career-card select:focus, .career-card textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
        .career-card select option { background: #fff; color: var(--text-body); }
        .career-card textarea { resize: vertical; min-height: 100px; }
        .career-card textarea#coverLetter { min-height: 120px; }
        .phone-wrapper { display: flex; gap: 10px; align-items: center; }
        .phone-wrapper select { width: 100px; flex-shrink: 0; padding: 12px 8px; }
        .phone-wrapper input { flex: 1; }
        .word-counter { display: flex; justify-content: flex-end; font-size: 0.8rem; color: var(--text-body); opacity: 0.6; margin-top: 4px; }
        .word-counter .count { font-weight: 700; color: var(--accent); }
        .word-counter .count.warning { color: #ef4444; }
        .terms-checkbox { display: flex; align-items: flex-start; gap: 10px; margin: 16px 0 24px 0; }
        .terms-checkbox input[type="checkbox"] { width: 18px; height: 18px; margin-top: 3px; flex-shrink: 0; accent-color: var(--accent); cursor: pointer; }
        .terms-checkbox label { font-size: 0.9rem; font-weight: 400; text-transform: none; opacity: 0.8; color: var(--text-body); cursor: pointer; }
        .terms-checkbox label a { color: var(--accent); font-weight: 600; text-decoration: underline; }
        .terms-checkbox label a:hover { color: var(--accent-hover); }
        .career-card .btn { width: 100%; padding: 16px; font-size: 1rem; font-weight: 700; }
        .career-card .hr-note { text-align: center; font-size: 0.85rem; color: var(--text-body); opacity: 0.5; margin-top: 16px; }
