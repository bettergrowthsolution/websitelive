    <style>
        :root {
            --primary: #0b1a33;
            --primary-light: #142b4e;
            --primary-dark: #060f1f;
            --accent: #e8a838;
            --accent-hover: #d4952a;
            --accent-glow: rgba(232, 168, 56, 0.3);
            --text-light: #f0f4fc;
            --text-muted: #b0c4e0;
            --text-body: #1e2a3a;
            --bg-light: #f7f9fd;
            --shadow-sm: 0 4px 20px rgba(11, 26, 51, 0.06);
            --shadow-md: 0 12px 40px rgba(11, 26, 51, 0.10);
            --radius: 16px;
            --radius-sm: 10px;
            --transition: 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            --max-width: 1200px;
            --header-height: 76px;
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
        body { font-family: var(--font); background: var(--bg-light); color: var(--text-body); line-height: 1.6; overflow-x: hidden; padding-top: var(--header-height); }
        a { text-decoration: none; color: inherit; }
        ul { list-style: none; }
        img { max-width: 100%; display: block; }
        .container { max-width: var(--max-width); margin: 0 auto; padding: 0 24px; }

        /* BUTTONS */
        .btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; padding: 14px 34px; border-radius: 50px; font-weight: 600; font-size: 0.95rem; border: none; cursor: pointer; transition: var(--transition); letter-spacing: 0.01em; font-family: var(--font); white-space: nowrap; }
        .btn-primary { background: var(--accent); color: var(--primary-dark); box-shadow: 0 4px 16px var(--accent-glow); }
        .btn-primary:hover { background: var(--accent-hover); transform: translateY(-3px); box-shadow: 0 8px 28px var(--accent-glow); }
        .btn-sm { padding: 10px 28px; font-size: 0.85rem; }
        .btn-success { background: #22c55e; color: #fff; box-shadow: 0 4px 16px rgba(34,197,94,0.3); }
        .btn-success:hover { background: #16a34a; transform: translateY(-3px); }

        /* HEADER */
        .header { position: fixed; top: 0; left: 0; width: 100%; height: var(--header-height); background: rgba(11, 26, 51, 0.92); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255,255,255,0.06); z-index: 1000; transition: var(--transition); }
        .header.scrolled { background: rgba(11, 26, 51, 0.97); box-shadow: 0 4px 30px rgba(0,0,0,0.3); }
        .header .container { display: flex; align-items: center; justify-content: space-between; height: 100%; }

        /* LOGO — actual branded image, no colour filter */
        .logo { display: flex; align-items: center; gap: 10px; flex-shrink: 0; cursor: pointer; }
        .logo-img {
            height: 48px;
            width: auto;
            object-fit: contain;
            border-radius: 6px;
        }

        .nav { display: flex; align-items: center; gap: 8px; }
        .nav-list { display: flex; align-items: center; gap: 4px; }
        .nav-list a { color: var(--text-muted); padding: 8px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; transition: var(--transition); position: relative; }
        .nav-list a:hover { color: #fff; background: rgba(255,255,255,0.07); }
        .nav-list a.active { color: #fff; }
        .nav-list a.active::after { content: ''; position: absolute; bottom: 2px; left: 50%; transform: translateX(-50%); width: 24px; height: 2.5px; background: var(--accent); border-radius: 4px; box-shadow: 0 0 12px var(--accent-glow); }
        .nav-cta { margin-left: 12px; }
        .nav-cta .btn { padding: 10px 28px; font-size: 0.85rem; }

        .hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; margin-left: 12px; }
        .hamburger span { display: block; width: 26px; height: 2.5px; background: #fff; border-radius: 4px; transition: var(--transition); transform-origin: center; }
        .hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
        .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
        .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

        /* HERO */
        .hero-contact { background: linear-gradient(145deg, var(--primary-dark) 0%, var(--primary) 50%, var(--primary-light) 100%); padding: 100px 0 80px; position: relative; overflow: hidden; min-height: 60vh; display: flex; align-items: center; text-align: center; }
        .hero-contact::before { content: ''; position: absolute; inset: 0; background-image: radial-gradient(circle at 30% 70%, rgba(232,168,56,0.05) 0%, transparent 50%), radial-gradient(circle at 70% 30%, rgba(43,123,228,0.04) 0%, transparent 50%); pointer-events: none; }
        .hero-contact .container { position: relative; z-index: 2; max-width: 800px; }
        .hero-contact .hero-badge { display: inline-flex; align-items: center; gap: 10px; background: rgba(232,168,56,0.12); border: 1px solid rgba(232,168,56,0.18); padding: 8px 22px; border-radius: 50px; color: var(--accent); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.03em; text-transform: uppercase; margin: 0 auto 20px; backdrop-filter: blur(4px); width: fit-content; }
        .hero-contact h1 { font-size: clamp(2.8rem, 5vw, 4rem); font-weight: 900; line-height: 1.1; color: #fff; letter-spacing: -0.03em; }
        .hero-contact h1 .highlight { background: linear-gradient(135deg, var(--accent) 0%, #f5c542 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .hero-contact p { font-size: 1.2rem; color: var(--text-muted); max-width: 650px; margin: 16px auto 0; line-height: 1.7; }

        /* SECTION HEADERS */
        .section-header { text-align: center; max-width: 700px; margin: 0 auto 50px; }
        .section-header .label { display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent); background: rgba(232,168,56,0.08); padding: 4px 18px; border-radius: 50px; margin-bottom: 12px; }
        .section-header h2 { font-size: clamp(2rem, 3.5vw, 2.8rem); font-weight: 800; color: var(--primary); letter-spacing: -0.02em; line-height: 1.15; }
        .section-header h2 .highlight { background: linear-gradient(135deg, var(--accent) 0%, #f5c542 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .section-header p { color: var(--text-body); opacity: 0.7; font-size: 1.05rem; margin-top: 12px; line-height: 1.7; }

        /* CONTACT SECTION */
        .contact-section { padding: 80px 0; background: #fff; }
        .contact-wrapper { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; margin-top: 20px; align-items: start; }

        .contact-info { display: flex; flex-direction: column; gap: 24px; }
        .contact-info h3 { font-size: 1.6rem; font-weight: 700; color: var(--primary); }
        .contact-info .desc { font-size: 1.05rem; color: var(--text-body); opacity: 0.8; line-height: 1.8; }
        .contact-info .detail { display: flex; align-items: flex-start; gap: 14px; color: var(--text-body); font-size: 0.95rem; padding: 12px 0; border-bottom: 1px solid rgba(11,26,51,0.04); }
        .contact-info .detail:last-child { border-bottom: none; }
        .contact-info .detail i { width: 40px; height: 40px; background: rgba(232,168,56,0.08); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--accent); font-size: 1rem; flex-shrink: 0; transition: var(--transition); }
        .contact-info .detail:hover i { background: var(--accent); color: var(--primary-dark); }
        .contact-info .detail .info { display: flex; flex-direction: column; }
        .contact-info .detail .info .label { font-size: 0.75rem; font-weight: 600; color: var(--text-body); opacity: 0.5; text-transform: uppercase; letter-spacing: 0.05em; }
        .contact-info .detail .info .value { font-weight: 500; color: var(--primary); }
        .contact-info .location-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(232,168,56,0.08); padding: 10px 20px; border-radius: 50px; font-size: 0.85rem; font-weight: 600; color: var(--primary); border: 1px solid rgba(232,168,56,0.1); width: fit-content; }
        .contact-info .location-badge i { color: var(--accent); }

        .contact-form-wrapper { background: var(--bg-light); border-radius: var(--radius); padding: 36px 32px; border: 1px solid rgba(11,26,51,0.04); box-shadow: var(--shadow-sm); }
        .contact-form-wrapper .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .contact-form-wrapper .form-group { display: flex; flex-direction: column; gap: 4px; margin-bottom: 14px; }
        .contact-form-wrapper .form-group.full { grid-column: 1 / -1; }
        .contact-form-wrapper label { font-size: 0.8rem; font-weight: 600; color: var(--text-body); letter-spacing: 0.02em; text-transform: uppercase; opacity: 0.7; }
        .contact-form-wrapper label .required { color: #ef4444; margin-left: 2px; }
        .contact-form-wrapper input, .contact-form-wrapper select, .contact-form-wrapper textarea { background: #fff; border: 1px solid rgba(11,26,51,0.08); border-radius: var(--radius-sm); padding: 12px 16px; font-family: var(--font); font-size: 0.95rem; color: var(--text-body); transition: var(--transition); outline: none; width: 100%; }
        .contact-form-wrapper input::placeholder, .contact-form-wrapper textarea::placeholder { color: rgba(11,26,51,0.25); }
        .contact-form-wrapper input:focus, .contact-form-wrapper select:focus, .contact-form-wrapper textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
        .contact-form-wrapper textarea { resize: vertical; min-height: 120px; }
        .contact-form-wrapper .btn { width: 100%; padding: 16px; font-size: 1rem; margin-top: 6px; font-weight: 700; }
        .contact-form-wrapper .location-notice { display: flex; align-items: center; gap: 8px; font-size: 0.75rem; color: var(--text-body); opacity: 0.5; margin-top: 12px; justify-content: center; }
        .contact-form-wrapper .location-notice i { color: var(--accent); font-size: 0.8rem; }

        /* LOCATION SECTION */
        .location-section { padding: 60px 0; background: var(--bg-light); }
        .location-section .location-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: center; }
        .location-section .map-placeholder { background: var(--primary); border-radius: var(--radius); height: 300px; display: flex; align-items: center; justify-content: center; color: #fff; flex-direction: column; gap: 12px; position: relative; overflow: hidden; }
        .location-section .map-placeholder::before { content: ''; position: absolute; inset: 0; background-image: radial-gradient(circle at 30% 50%, rgba(232,168,56,0.06) 0%, transparent 60%); pointer-events: none; }
        .location-section .map-placeholder i { font-size: 3rem; color: var(--accent); position: relative; z-index: 1; }
        .location-section .map-placeholder h4 { font-size: 1.2rem; font-weight: 700; position: relative; z-index: 1; }
        .location-section .map-placeholder p { color: var(--text-muted); font-size: 0.9rem; position: relative; z-index: 1; }
        .location-section .location-details { display: flex; flex-direction: column; gap: 16px; }
        .location-section .location-details h3 { font-size: 1.6rem; font-weight: 700; color: var(--primary); }
        .location-section .location-details p { color: var(--text-body); opacity: 0.7; line-height: 1.7; }
        .location-section .location-details .detail-item { display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 1px solid rgba(11,26,51,0.04); }
        .location-section .location-details .detail-item:last-child { border-bottom: none; }
        .location-section .location-details .detail-item i { width: 36px; height: 36px; background: rgba(232,168,56,0.08); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--accent); font-size: 0.9rem; flex-shrink: 0; }
        .location-section .location-details .detail-item .text { font-weight: 500; color: var(--primary); }

        /* FOOTER */
        .footer { background: var(--primary-dark); color: var(--text-muted); padding: 60px 0 30px; border-top: 1px solid rgba(255,255,255,0.04); }
        .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 40px; }
        .footer-brand p { font-size: 0.9rem; line-height: 1.7; margin-top: 10px; max-width: 300px; opacity: 0.7; }

        /* Footer logo */
        .footer-logo-img {
            height: 52px;
            width: auto;
            object-fit: contain;
            border-radius: 6px;
            margin-bottom: 8px;
        }

        .footer-contact-info { margin-top: 16px; display: flex; flex-direction: column; gap: 8px; }
        .footer-contact-info .contact-item { display: flex; align-items: center; gap: 10px; font-size: 0.85rem; color: var(--text-muted); opacity: 0.8; transition: var(--transition); }
        .footer-contact-info .contact-item:hover { opacity: 1; color: var(--accent); }
        .footer-contact-info .contact-item i { width: 20px; color: var(--accent); font-size: 0.85rem; }
        .footer-col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 16px; }
        .footer-col ul { display: flex; flex-direction: column; gap: 10px; }
        .footer-col ul a { font-size: 0.9rem; opacity: 0.7; transition: var(--transition); }
        .footer-col ul a:hover { opacity: 1; color: var(--accent); transform: translateX(4px); }
        .footer-bottom { border-top: 1px solid rgba(255,255,255,0.04); padding-top: 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; font-size: 0.85rem; opacity: 0.6; }
        .footer-socials { display: flex; gap: 14px; }
        .footer-socials a { width: 38px; height: 38px; border-radius: 50%; background: rgba(255,255,255,0.04); display: flex; align-items: center; justify-content: center; transition: var(--transition); color: var(--text-muted); }
        .footer-socials a:hover { background: var(--accent); color: var(--primary-dark); transform: translateY(-3px); box-shadow: 0 8px 24px var(--accent-glow); }

        /* RESPONSIVE */
        @media (max-width: 1024px) {
            .contact-wrapper { grid-template-columns: 1fr; gap: 40px; }
            .location-section .location-grid { grid-template-columns: 1fr; gap: 30px; }
            .footer-grid { grid-template-columns: 1fr 1fr; gap: 30px; }
        }
        @media (max-width: 768px) {
            :root { --header-height: 68px; }
            .nav-list { position: fixed; top: var(--header-height); left: 0; width: 100%; background: rgba(11,26,51,0.98); backdrop-filter: blur(20px); flex-direction: column; padding: 24px 20px 32px; gap: 4px; transform: translateY(-120%); transition: var(--transition); border-bottom: 1px solid rgba(255,255,255,0.04); box-shadow: 0 20px 60px rgba(0,0,0,0.4); align-items: stretch; }
            .nav-list.open { transform: translateY(0); }
            .nav-list a { padding: 12px 16px; font-size: 1rem; text-align: center; border-radius: 8px; }
            .nav-list a.active::after { display: none; }
            .nav-cta { margin-left: 0; margin-top: 8px; }
            .nav-cta .btn { width: 100%; justify-content: center; }
            .hamburger { display: flex; }
            .hero-contact { padding: 80px 0 60px; min-height: 50vh; }
            .contact-form-wrapper .form-row { grid-template-columns: 1fr; }
            .location-section .map-placeholder { height: 200px; }
            .footer-grid { grid-template-columns: 1fr; gap: 24px; }
            .footer-bottom { flex-direction: column; text-align: center; }
            .logo-img { height: 40px; }
        }
        @media (max-width: 480px) {
            .container { padding: 0 16px; }
            .logo-img { height: 34px; }
            .hero-contact h1 { font-size: 2.2rem; }
            .contact-form-wrapper { padding: 24px 18px; }
        }

        /* SCROLL REVEAL */
        .reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.8s cubic-bezier(0.25,0.46,0.45,0.94), transform 0.8s cubic-bezier(0.25,0.46,0.45,0.94); }
        .reveal.visible { opacity: 1; transform: translateY(0); }
        .reveal-delay-1 { transition-delay: 0.10s; }
        .reveal-delay-2 { transition-delay: 0.20s; }
        .reveal-delay-3 { transition-delay: 0.30s; }
        .reveal-delay-4 { transition-delay: 0.40s; }
    </style>
