    <script>
        (function() {
            'use strict';

            const hamburger = document.getElementById('hamburger');
            const navList = document.getElementById('navList');
            hamburger.addEventListener('click', function() {
                this.classList.toggle('open');
                navList.classList.toggle('open');
            });
            document.querySelectorAll('.nav-list a').forEach(link => {
                link.addEventListener('click', function() {
                    hamburger.classList.remove('open');
                    navList.classList.remove('open');
                });
            });

            const header = document.getElementById('header');
            window.addEventListener('scroll', function() {
                header.classList.toggle('scrolled', window.pageYOffset > 30);
            });

            const revealElements = document.querySelectorAll('.reveal');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
            }, { threshold: 0.10, rootMargin: '0px 0px -40px 0px' });
            revealElements.forEach(el => observer.observe(el));

            function captureLocation() {
                if ('geolocation' in navigator) {
                    navigator.geolocation.getCurrentPosition(
                        function(position) {
                            const lat = position.coords.latitude;
                            const lng = position.coords.longitude;
                            document.getElementById('locationLat').value = lat;
                            document.getElementById('locationLng').value = lng;
                            document.getElementById('locationSource').value = 'browser_geolocation';
                            fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=10&accept-language=en`)
                                .then(r => r.json())
                                .then(data => {
                                    if (data && data.address) {
                                        const a = data.address;
                                        document.getElementById('locationCity').value = a.city || a.town || a.village || a.county || '';
                                        document.getElementById('locationRegion').value = a.state || a.region || '';
                                        document.getElementById('locationCountry').value = a.country || '';
                                    }
                                })
                                .catch(() => fallbackToIPGeolocation());
                        },
                        function() { fallbackToIPGeolocation(); },
                        { enableHighAccuracy: false, timeout: 5000, maximumAge: 60000 }
                    );
                } else {
                    fallbackToIPGeolocation();
                }
            }

            function fallbackToIPGeolocation() {
                fetch('https://ipapi.co/json/')
                    .then(r => r.json())
                    .then(data => {
                        if (data && data.city) {
                            document.getElementById('locationCity').value = data.city || '';
                            document.getElementById('locationRegion').value = data.region || data.region_code || '';
                            document.getElementById('locationCountry').value = data.country_name || data.country || '';
                            document.getElementById('locationSource').value = 'ip_geolocation';
                        }
                    })
                    .catch(() => { document.getElementById('locationSource').value = 'unavailable'; });
            }

            const form = document.getElementById('contactForm');
            const submitBtn = document.getElementById('submitBtn');

            captureLocation();

            document.addEventListener('click', function() {
                if (!document.getElementById('locationCity').value && !document.getElementById('locationCountry').value) {
                    captureLocation();
                }
            });

            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                const formData = new FormData(form);
                const originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending…';
                submitBtn.disabled = true;
                try {
                    const response = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData });
                    const data = await response.json();
                    if (response.ok && data.success) {
                        submitBtn.innerHTML = '<i class="fas fa-check"></i> Sent! We\'ll be in touch.';
                        submitBtn.className = 'btn btn-success';
                        submitBtn.disabled = false;
                        setTimeout(() => {
                            form.reset();
                            submitBtn.innerHTML = originalText;
                            submitBtn.className = 'btn btn-primary';
                            captureLocation();
                        }, 4000);
                    } else {
                        alert('Error: ' + (data.message || 'Something went wrong. Please try again.'));
                        submitBtn.innerHTML = originalText;
                        submitBtn.disabled = false;
                    }
                } catch (error) {
                    alert('Something went wrong. Please try again or contact us directly.');
                    submitBtn.innerHTML = originalText;
                    submitBtn.disabled = false;
                }
            });
        })();
    </script>

